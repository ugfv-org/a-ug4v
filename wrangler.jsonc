{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "a-ug4v",
  "compatibility_date": "2026-04-29",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "a.ug4v.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
